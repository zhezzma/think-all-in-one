{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "WebWorker"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["vitest/globals"]
  },
  "include": [
    "vitest.config.ts",
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "worker/**/*.ts",
    "worker/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist", "coverage"]
}
